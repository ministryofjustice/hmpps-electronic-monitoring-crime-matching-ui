{
  "name": "hmpps-electronic-monitoring-crime-matching-ui",
  "version": "0.0.1",
  "description": "HMPPS Electronic Monitoring Crime Matching Ui",
  "repository": "git@github.com:ministryofjustice/hmpps-electronic-monitoring-crime-matching-ui.git",
  "license": "MIT",
  "scripts": {
    "prepare": "hmpps-precommit-hooks-prepare",
    "watch-ts": "tsc -w",
    "build": "node esbuild/esbuild",
    "start": "node $NODE_OPTIONS dist/server.js | bunyan -o short",
    "start:dev": "node esbuild/esbuild --watch",
    "start-feature": " node $NODE_DEBUG_OPTION --env-file=feature.env dist/server.js | bunyan -o short",
    "start-feature:dev": "node esbuild/esbuild --watch --env feature.env",
    "lint": "eslint . --cache --max-warnings 0",
    "lint-fix": "eslint . --cache --max-warnings 0 --fix",
    "typecheck": "tsc && tsc -p integration_tests",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "security_audit": "npx audit-ci --config audit-ci.json",
    "int-test": "cypress run --config video=false",
    "int-test-ui": "cypress open --e2e --browser chrome",
    "int-test-init:ci": "npx playwright install",
    "clean": "rm -rf dist test_results",
    "rebuild": "npm run clean && npm run setup && npm run build",
    "setup": "npm ci && hmpps-npm-script-run-allowlist"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1090.0",
    "@ministryofjustice/frontend": "^9.0.0",
    "@ministryofjustice/hmpps-auth-clients": "1.0.2",
    "@ministryofjustice/hmpps-azure-telemetry": "1.0.2",
    "@ministryofjustice/hmpps-electronic-monitoring-components": "0.2.20",
    "@ministryofjustice/hmpps-monitoring": "1.1.0",
    "@ministryofjustice/hmpps-probation-frontend-components": "^1.0.3",
    "@ministryofjustice/hmpps-rest-client": "1.2.1",
    "@types/archiver": "7.0.0",
    "@types/qs": "^6.15.1",
    "agentkeepalive": "^4.6.0",
    "axios": "1.18.1",
    "body-parser": "^2.3.0",
    "bunyan": "^1.8.15",
    "bunyan-format": "^0.2.1",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-redis": "^9.0.0",
    "csrf-sync": "^4.2.1",
    "csv-stringify": "6.8.1",
    "dayjs": "^1.11.21",
    "docx": "9.7.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "file-type": "22.0.1",
    "govuk-frontend": "^6.4.0",
    "helmet": "^8.3.0",
    "http-errors": "^2.0.1",
    "image-size": "2.0.2",
    "jwt-decode": "^4.0.0",
    "multer": "2.2.0",
    "nocache": "^4.0.0",
    "nunjucks": "^3.2.4",
    "ol": "^10.9.0",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.8.0",
    "playwright": "1.61.1",
    "redis": "^5.12.1",
    "superagent": "^10.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jgoz/esbuild-plugin-typecheck": "^4.0.4",
    "@ministryofjustice/eslint-config-hmpps": "1.0.3",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.6",
    "@ministryofjustice/hmpps-precommit-hooks": "2.0.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/bunyan": "^1.8.11",
    "@types/bunyan-format": "^0.2.9",
    "@types/compression": "^1.8.1",
    "@types/connect-flash": "0.0.40",
    "@types/express-session": "^1.19.0",
    "@types/govuk-frontend": "5.11.0",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "2.2.0",
    "@types/node": "^22.20.1",
    "@types/nunjucks": "^3.2.6",
    "@types/passport": "^1.0.17",
    "@types/passport-oauth2": "^1.8.0",
    "@types/superagent": "^8.1.11",
    "@types/supertest": "^7.2.1",
    "audit-ci": "^7.1.0",
    "aws-sdk-client-mock": "^4.1.0",
    "concurrently": "^9.2.4",
    "cypress": "^15.18.1",
    "cypress-multi-reporters": "^2.0.5",
    "del": "8.0.1",
    "esbuild": "0.28.1",
    "esbuild-plugin-clean": "^1.0.1",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-manifest": "^1.0.5",
    "esbuild-sass-plugin": "^3.7.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "17.0.0",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^16.4.0",
    "mocha-junit-reporter": "^2.2.1",
    "nock": "^14.0.16",
    "prettier": "^3.9.5",
    "prettier-plugin-jinja-template": "^2.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "uuid": "^13.0.2"
  },
  "overrides": {
    "@opentelemetry/core": "2.9.0"
  }
}
