{% extends "../../partials/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/tabs/macro.njk" import govukTabs %}
{% from "../../components/map/macro.njk" import appMap %}
{% from "../../components/date-time-picker/macro.njk" import dateTimePicker %}

{% set pageTitle = applicationName + " - Home" %}
{% set containerClasses = "govuk-full-width-container-no-gutter" %}
{% set mainClasses = "app-container govuk-body map-container location-data" %}
{%
  set mainAttributes = {
    "data-page": "subject"
  }
%}
{% set activeLinkId = "location-data" %}


{% set timeHtml %}
  {% include "./partials/dateFilterForm.njk" %}

  <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible" />

  {% include "./partials/exportForm.njk" %}
{% endset %}


{% set analysisHtml %}
  {{
    govukCheckboxes({
      classes: "govuk-checkboxes--small",
      name: "analysis-toggles",
      attributes: {
        "data-module": 'map-layer-visibility-toggle'
      },
      items: [
        {
          checked: true,
          text: "Show locations",
          value: "pointsLayer"
        },
        {
          text: "Show confidence circles",
          value: "confidenceLayer"
        },
        {
          text: "Show tracks",
          value: "tracksLayer"
        },
        {
          text: "Show location numbering",
          value: "numberingLayer"
        }
      ]
    })
  }}
{% endset %}


{% set sidebarHtml %}
  {{
    govukTabs({
      items: [
        {
          label: "Time",
          id: "time",
          panel: {
            html: timeHtml
          }
        },
        {
          label: "Analysis",
          id: "analysis",
          panel: {
            html: analysisHtml
          }
        }
      ]
    })
  }}
{% endset %}

{% block content %}

  {{
    appMap({
      cspNonce: cspNonce,
      positions: positions,
      alerts: alerts,
      usesInternalOverlays: true,
      sidebarHtml: sidebarHtml
    })
  }}

  {# The {{ }} placeholders are not processed by Nunjucks.
      They are used as markers and replaced within assets/js files at runtime.
      Implemented this way to avoid large Template Literals in the JavaScript file. #}
  {% raw %}
    <template id="overlay-title-mdss-location">
      <div><strong>Name (NOMIS ID):</strong> {{ subjectName }} ({{ subjectNomisId }})</div>
      <div><strong>Device ID:</strong> {{ subjectDeviceId }}</div>
      <div><strong>Date of birth:</strong> {{ subjectDateOfBirth }}</div>
      <div><strong>Main address:</strong> {{ subjectAddress }}</div>
      <div><strong>Tag start date:</strong> {{ subjectTagStartDate }}</div>
      <div><strong>Tag end date:</strong> {{ subjectTagEndDate }}</div>
    </template>

    <template id="overlay-body-mdss-location">
      <div class="app-map__overlay-row" part="app-map__overlay-row">
        <span class="app-map__overlay-label">Confidence (m)</span>
        <span class="app-map__overlay-value">{{ precision }}</span>
      </div>
      <div class="app-map__overlay-row">
        <span class="app-map__overlay-label">Speed (km/h)</span>
        <span class="app-map__overlay-value">{{ speed }}</span>
      </div>
      <div class="app-map__overlay-row">
        <span class="app-map__overlay-label">Direction (degrees)</span>
        <span class="app-map__overlay-value">{{ displayDirection }}</span>
      </div>
      <div class="app-map__overlay-row" part="app-map__overlay-row">
        <span class="app-map__overlay-label">Geolocation mechanism</span>
        <span class="app-map__overlay-value">{{ geolocationMechanism }}</span>
      </div>
      <div class="app-map__overlay-row" part="app-map__overlay-row">
        <span class="app-map__overlay-label">Recorded date/time</span>
        <span class="app-map__overlay-value">{{ displayTimestamp }}</span>
      </div>
      <div class="app-map__overlay-row" part="app-map__overlay-row">
        <span class="app-map__overlay-label">Location (latitude, longitude)</span>
        <span class="app-map__overlay-value" data-copy-value="{{ latitude }}, {{ longitude }}">
          {{ latitude }}, {{ longitude }}
        </span>
        <a href="#" class="app-map__copy-link govuk-link">Copy</a>
      </div>
    </template>
  {% endraw %}
{% endblock %}
