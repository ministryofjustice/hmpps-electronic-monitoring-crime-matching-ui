{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/table/macro.njk" import govukTable %}

<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <div class="datatable {% if params.classes %}{{ params.classes }}{% endif %}">
      {% if params.rows.length %}
        {{
          govukTable({
            caption: params.caption,
            captionClasses: params.captionClasses,
            head: params.columns,
            rows: params.rows,
            classes: params.tableClasses
          })
        }}

        {% if params.pagination.pageCount > 1 %}
          {{
            govukPagination(
              pagination(
                params.pagination.currentPage,
                params.pagination.pageCount,
                params.pagination.hrefPrefix
              )
            )
          }}
        {% endif %}
      {% else %}
        <p class="govuk-body" data-qa="no-results-message">There are no results.</p>
      {% endif %}
    </div>
  </div>
</div>
